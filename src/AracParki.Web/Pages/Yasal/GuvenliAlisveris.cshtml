@page "/guvenli-alisveris"
@inject SiteUrls SiteUrls
@{
    ViewData["PageKey"] = "legal";
    ViewData["Title"] = "Güvenli Alışveriş | İş Makinesi Alım-Satım İpuçları";
    ViewData["Description"] = "İş makinesi alım, satım ve kiralamada güvenli alışveriş: yerinde kontrol, belge doğrulama, kapora riski ve satıcı için dürüst ilan ipuçları.";
    ViewData["CanonicalUrl"] = SiteUrls.Absolute("/guvenli-alisveris");
    ViewData["OgTitle"] = "Güvenli Alışveriş | Araç Parkı";
    var crumbs = Breadcrumbs.Create(
        new BreadcrumbItem("Anasayfa", "/"),
        new BreadcrumbItem("Güvenli alışveriş", "/guvenli-alisveris"));
    Breadcrumbs.Set(ViewData, SiteUrls, crumbs);
}

@section CrumbBar {
  <partial name="Shared/Partials/_SiteBreadcrumb" model="crumbs" />
}

<main class="legal-page" id="main">
  <article class="legal-article container">
    <header class="legal-hero legal-hero--compact">
      <p class="legal-eyebrow">Yardım · Güvenlik</p>
      <h1>Güvenli alışveriş ipuçları</h1>
      <p class="legal-lead">
        İş makinesi alım, satım ve kiralama yüksek tutarlı işlemlerdir.
        Aşağıdaki kontrol listesi riskleri azaltmanıza yardımcı olur.
      </p>
    </header>

    <h2>Alıcılar için</h2>
    <ul class="legal-check">
      <li>Makineyi yerinde görün; mümkünse çalışır durumda test edin</li>
      <li>Seri no, saat, bakım geçmişi ve fatura / ruhsat belgelerini isteyin</li>
      <li>Görmeden kapora veya peşinat göndermeyin</li>
      <li>Aşırı düşük fiyatlara temkinli yaklaşın; şüpheli ilanları bildirin</li>
    </ul>

    <h2>Satıcılar için</h2>
    <ul class="legal-check">
      <li>Doğru kategori, net fotoğraf ve dürüst arıza beyanı kullanın</li>
      <li>Telefon doğrulamasını tamamlayın; güven sinyalleri alıcıyı ikna eder</li>
      <li>Ödemeyi güvenli kanallardan alın; nakit riskini bilin</li>
    </ul>

    <aside class="legal-note" aria-label="Platform notu">
      <strong>Platform notu</strong>
      Araç Parkı ilanları kullanıcılar tarafından oluşturulur; platform aracı veya mal sahibi
      değildir. Anlaşmazlıklarda taraflar kendi hukuki yollarını kullanır. Acil güvenlik
      şüphesinde en yakın yetkili mercilere başvurun.
    </aside>

    <nav class="legal-related" aria-label="İlgili sayfalar">
      <a href="/ilanlar">İlanlara dön</a>
      <a href="/yardim">Yardım merkezi</a>
      <a href="/iletisim">İletişim</a>
      <a href="/ilan-kurallari">İlan kuralları</a>
    </nav>
  </article>
</main>

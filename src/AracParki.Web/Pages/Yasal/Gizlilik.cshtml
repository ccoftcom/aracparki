@page "/gizlilik"
@inject SiteUrls SiteUrls
@{
    ViewData["PageKey"] = "legal";
    ViewData["Title"] = "Gizlilik Bildirimi | Araç Parkı";
    ViewData["Description"] = "Araç Parkı gizlilik bildirimi: hangi kişisel verileri topladığımız, çerezler, paylaşım ilkeleri ve haklarınız.";
    ViewData["CanonicalUrl"] = SiteUrls.Absolute("/gizlilik");
    ViewData["OgTitle"] = "Gizlilik Bildirimi | Araç Parkı";
    var crumbs = Breadcrumbs.Create(
        new BreadcrumbItem("Anasayfa", "/"),
        new BreadcrumbItem("Gizlilik bildirimi", "/gizlilik"));
    Breadcrumbs.Set(ViewData, SiteUrls, crumbs);
}

@section CrumbBar {
  <partial name="Shared/Partials/_SiteBreadcrumb" model="crumbs" />
}

<main class="legal-page" id="main">
  <article class="legal-article container">
    <h1>Gizlilik bildirimi</h1>
    <p class="legal-updated">Son güncelleme: 19 Temmuz 2026</p>

    <p>
      Araç Parkı olarak kişisel verilerinizi yalnızca hizmeti sunmak, güvenliği sağlamak ve yasal
      yükümlülükleri yerine getirmek için işleriz. Detaylı haklarınız için
      <a href="/kvkk">KVKK aydınlatma metni</a>ne bakın.
    </p>

    <h2>Topladığımız veriler</h2>
    <ul>
      <li>Hesap: ad soyad, e-posta, şifre özeti, isteğe bağlı telefon</li>
      <li>İlan ve kullanım: ilan içerikleri, arama tercihleri, teknik loglar</li>
      <li>İletişim: destek talepleri ve site içi mesajlaşma (yakında)</li>
    </ul>

    <h2>Çerezler</h2>
    <p>
      Oturum (giriş), güvenlik ve temel analitik için zorunlu çerezler kullanılır.
      Ayrıntılar için <a href="/cerez-politikasi">çerez politikası</a>na bakın.
      Pazarlama çerezleri için ileride ayrı tercih yönetimi sunulacaktır.
    </p>

    <h2>Paylaşım</h2>
    <p>
      Verilerinizi yasal zorunluluk olmadıkça veya hizmetin çalışması için gerekli altyapı
      sağlayıcıları dışında üçüncü taraflarla satmayız / pazarlamayız.
    </p>

    <nav class="legal-related" aria-label="İlgili sayfalar">
      <a href="/kullanim-kosullari">Kullanım koşulları</a>
      <a href="/kvkk">KVKK</a>
      <a href="/cerez-politikasi">Çerez politikası</a>
    </nav>
  </article>
</main>

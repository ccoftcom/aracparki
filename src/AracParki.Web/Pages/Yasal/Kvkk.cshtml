@page "/kvkk"
@inject SiteUrls SiteUrls
@{
    ViewData["PageKey"] = "legal";
    ViewData["Title"] = "KVKK Aydınlatma Metni | Araç Parkı";
    ViewData["Description"] = "6698 sayılı KVKK kapsamında Araç Parkı aydınlatma metni: veri sorumlusu, işlenen veriler, amaçlar ve haklarınız.";
    ViewData["CanonicalUrl"] = SiteUrls.Absolute("/kvkk");
    ViewData["OgTitle"] = "KVKK Aydınlatma | Araç Parkı";
    var crumbs = Breadcrumbs.Create(
        new BreadcrumbItem("Anasayfa", "/"),
        new BreadcrumbItem("KVKK aydınlatma metni", "/kvkk"));
    Breadcrumbs.Set(ViewData, SiteUrls, crumbs);
}

@section CrumbBar {
  <partial name="Shared/Partials/_SiteBreadcrumb" model="crumbs" />
}

<main class="legal-page" id="main">
  <article class="legal-article container">
    <h1>KVKK aydınlatma metni</h1>
    <p class="legal-updated">Son güncelleme: 19 Temmuz 2026</p>

    <p>
      6698 sayılı Kişisel Verilerin Korunması Kanunu’nun 10. maddesi uyarınca, Araç Parkı
      (“Veri Sorumlusu”) olarak kişisel verilerinizin işlenmesine ilişkin bilgilendirme aşağıdadır.
      Bu metin bilgilendirme amaçlıdır; hukuki danışmanlık yerine geçmez.
    </p>

    <h2>1. Veri sorumlusu</h2>
    <p>
      Araç Parkı — aracparki.com. İletişim için site üzerinden yayınlanan destek kanallarını kullanın.
    </p>

    <h2>2. İşlenen veriler ve amaçlar</h2>
    <ul>
      <li>Kimlik ve iletişim: üyelik, doğrulama, bildirim</li>
      <li>İşlem güvenliği: oturum, dolandırıcılık önleme, log kayıtları</li>
      <li>İlan verileri: pazar yeri hizmetinin sunulması</li>
    </ul>

    <h2>3. Hukuki sebepler</h2>
    <p>
      Sözleşmenin kurulması/ifası, meşru menfaat, hukuki yükümlülük ve açık rıza (gerektiğinde)
      kapsamında işleme yapılır.
    </p>

    <h2>4. Haklarınız</h2>
    <p>
      Kanun’un 11. maddesi kapsamında verilerinize erişme, düzeltme, silme, itiraz ve şikâyet
      haklarınızı kullanabilirsiniz. Taleplerinizi yazılı olarak iletebilirsiniz.
    </p>

    <nav class="legal-related" aria-label="İlgili sayfalar">
      <a href="/gizlilik">Gizlilik</a>
      <a href="/cerez-politikasi">Çerez politikası</a>
      <a href="/kullanim-kosullari">Kullanım koşulları</a>
    </nav>
  </article>
</main>

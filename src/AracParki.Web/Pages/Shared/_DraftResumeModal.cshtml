@model AracParki.Web.Pages.IlanVer.IndexModel
@{
    var resume = Model.DraftResume;
    var updated = resume is null ? "" : Formatters.DateTime(resume.UpdatedAt);
    var step = resume?.Step ?? 1;
    var stepLabel = resume?.StepLabel ?? "Taslak";
    var progressPct = Math.Clamp(step, 1, 5) * 20;
}
<div class="ap-draft-gate"
     x-data="draftResumeModal"
     role="dialog"
     aria-modal="true"
     aria-labelledby="draft-resume-title"
     aria-describedby="draft-resume-desc"
     x-trap.noscroll.inert="true"
     @@keydown.escape.prevent.stop>
  <div class="ap-draft-gate__backdrop" aria-hidden="true"></div>

  <div class="ap-draft-gate__dialog" @@click.stop>
    <header class="ap-draft-gate__header">
      <p class="ap-draft-gate__kicker">Kayıtlı taslak</p>
      <h2 id="draft-resume-title" class="ap-draft-gate__title">Kaldığın yerden devam et</h2>
      <p id="draft-resume-desc" class="ap-draft-gate__lead">
        Yarım kalan ilanın hazır. Devam edebilir veya taslağı (fotoğraflar dahil) kalıcı olarak silip sıfırdan başlayabilirsin.
      </p>
    </header>

    <div class="ap-draft-gate__body">
      @if (resume is not null)
      {
        <div class="ap-draft-gate__progress" aria-hidden="true">
          <div class="ap-draft-gate__progress-track">
            <span class="ap-draft-gate__progress-fill" style="width: @progressPct%"></span>
          </div>
          <p class="ap-draft-gate__progress-label">Adım @step / 5 · @stepLabel</p>
        </div>

        <dl class="ap-draft-gate__summary">
          @if (!string.IsNullOrWhiteSpace(resume.CategoryName))
          {
            <div>
              <dt>Kategori</dt>
              <dd>@resume.CategoryName</dd>
            </div>
          }
          @if (!string.IsNullOrWhiteSpace(resume.Title))
          {
            <div>
              <dt>Başlık</dt>
              <dd>@resume.Title</dd>
            </div>
          }
          <div>
            <dt>Fotoğraf</dt>
            <dd>@resume.ImageCount adet</dd>
          </div>
          <div>
            <dt>Son kayıt</dt>
            <dd>@updated</dd>
          </div>
        </dl>
      }
    </div>

    <footer class="ap-draft-gate__footer">
      <form method="post" asp-page-handler="StartNewDraft" class="ap-draft-gate__form-action">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-ghost ap-draft-gate__secondary">
          Taslağı sil, yeni başlat
        </button>
      </form>
      <form method="post" asp-page-handler="ContinueDraft" class="ap-draft-gate__form-action">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-machine ap-draft-gate__primary" autofocus>
          Taslağa devam et
        </button>
      </form>
    </footer>
  </div>
</div>

@{
    Layout = "_Layout";
    var path = Context.Request.Path.Value ?? string.Empty;
    var isAdminArea = path.StartsWith("/admin", StringComparison.OrdinalIgnoreCase);
}
<main class="container page-account" id="main">
  <div class="account-layout">
    <aside class="account-aside" aria-label="@(isAdminArea ? "Admin menüsü" : "Hesap menüsü")">
      <nav class="account-nav" data-account-nav>
        @if (isAdminArea)
        {
          <partial name="Shared/Partials/_AdminNav" />
        }
        else
        {
          <partial name="Shared/Partials/_AccountNav" />
        }
      </nav>
    </aside>
    <div class="account-main">
      @RenderBody()
    </div>
  </div>
</main>

@section Scripts {
  @await RenderSectionAsync("Scripts", required: false)
}

@section CrumbBar {
  @await RenderSectionAsync("CrumbBar", required: false)
}
